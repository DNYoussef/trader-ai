+    def _handle_missing_values_test(self, df: pd.DataFrame) -> pd.DataFrame:
+        """
+        Handle missing values in TEST data - uses fitted imputer
+
+        IMPORTANT: This method ONLY transforms using the imputer fitted on training data.
+        It does NOT refit the imputer, preventing test data from influencing the
+        imputation strategy and ensuring proper train/test separation.
+
+        Args:
+            df: Test dataframe
+
+        Returns:
+            Test dataframe with imputed values
+
+        Raises:
+            ValueError: If imputer has not been fitted on training data first
+        """
+        logger.info("Handling missing values in TEST data")
+
+        if 'numeric' not in self.imputers:
+            raise ValueError(
+                "Imputer has not been fitted. Call _handle_missing_values_train() on "
+                "training data before processing test data."
+            )
+
+        numeric_columns = df.select_dtypes(include=[np.number]).columns
+        missing_info = df[numeric_columns].isnull().sum()
+
+        if missing_info.sum() > 0:
+            logger.info(f"Found missing values: {missing_info[missing_info > 0].to_dict()}")
+
+        # TRANSFORM ONLY using fitted imputer - NO FITTING
+        df[numeric_columns] = self.imputers['numeric'].transform(df[numeric_columns])
